<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2013/05/nuspec.xsd">
  <metadata>
    <id>Brigadier.NET</id>
    <version>1.2.13</version>
    <authors>Steven Blom</authors>
    <license type="expression">MIT</license>
    <licenseUrl>https://licenses.nuget.org/MIT</licenseUrl>
    <projectUrl>https://github.com/AtomicBlom/Brigadier.NET</projectUrl>
    <description>Brigadier.NET is a port of Mojang's brigadier command line parser &amp; dispatcher, originally for Minecraft: Java Edition and now freely available for use elsewhere under the MIT license.

This port is not supported by Mojang or Microsoft.</description>
    <tags>Brigadier command line parser dispatcher</tags>
    <repository url="https://github.com/AtomicBlom/Brigadier.NET" />
    <dependencies>
      <group targetFramework=".NETStandard1.1">
        <dependency id="NETStandard.Library" version="1.6.1" exclude="Build,Analyzers" />
        <dependency id="System.Memory" version="4.5.1" exclude="Build,Analyzers" />
      </group>
      <group targetFramework=".NETStandard2.0">
        <dependency id="System.Memory" version="4.5.1" exclude="Build,Analyzers" />
      </group>
    </dependencies>
  </metadata>
</package>